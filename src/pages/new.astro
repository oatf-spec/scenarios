---
import NewScenarioPage from '../components/NewScenarioPage';
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Scenario | OATF Scenarios</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
    <Analytics />
  </head>
  <body>
    <div class="min-h-screen bg-bg">
      <header class="h-16 border-b border-border flex items-center justify-between px-6" style="background: rgba(15,17,23,0.96);">
        <div class="flex items-center gap-6">
          <a href="/" class="inline-flex items-center gap-3 text-[15px] font-semibold text-text">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M2 13.5L7 2.5" stroke="#E4E4E7" stroke-width="1.75" stroke-linecap="round"/>
              <path d="M7.5 15.5L12.5 4.5" stroke="#E4E4E7" stroke-width="1.75" stroke-linecap="round"/>
              <path d="M13 15.5L16 8.8" stroke="#E4E4E7" stroke-width="1.75" stroke-linecap="round"/>
            </svg>
            <span>OATF Scenarios</span>
          </a>
          <nav class="hidden md:flex items-center gap-6">
            <a class="text-sm text-text-2 hover:text-text" href="/">Registry</a>
            <a class="text-sm text-text-2 hover:text-text" href="#" title="Coming soon">Coverage</a>
            <a class="text-sm text-text-2 hover:text-text" href="#" title="Coming soon">About</a>
          </nav>
        </div>
        <div class="flex items-center gap-6">
          <a class="text-sm text-text-2 hover:text-text hidden md:inline" href="https://oatf.io" target="_blank" rel="noopener">oatf.io</a>
          <a href="https://github.com/oatf-spec/scenarios" target="_blank" rel="noopener" aria-label="GitHub" class="text-text-2 hover:text-text">
            <svg class="w-4 h-4" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 0.2C3.58 0.2 0 3.78 0 8.2C0 11.74 2.29 14.74 5.47 15.8C5.87 15.87 6.02 15.63 6.02 15.42C6.02 15.24 6.01 14.66 6.01 13.89C3.78 14.37 3.31 12.95 3.31 12.95C2.95 12.03 2.43 11.79 2.43 11.79C1.71 11.3 2.49 11.31 2.49 11.31C3.29 11.36 3.71 12.13 3.71 12.13C4.42 13.34 5.57 12.99 6.03 12.79C6.1 12.28 6.31 11.93 6.54 11.73C4.76 11.53 2.89 10.84 2.89 7.75C2.89 6.87 3.2 6.15 3.72 5.58C3.64 5.38 3.37 4.56 3.8 3.46C3.8 3.46 4.47 3.25 6 4.28C6.64 4.1 7.32 4.01 8 4.01C8.68 4.01 9.36 4.1 10 4.28C11.53 3.25 12.2 3.46 12.2 3.46C12.63 4.56 12.36 5.38 12.28 5.58C12.8 6.15 13.11 6.87 13.11 7.75C13.11 10.85 11.24 11.53 9.45 11.73C9.74 11.98 10 12.49 10 13.27C10 14.38 9.99 15.19 9.99 15.42C9.99 15.63 10.13 15.88 10.54 15.8C13.71 14.74 16 11.74 16 8.2C16 3.78 12.42 0.2 8 0.2Z"/>
            </svg>
          </a>
        </div>
      </header>

      <main>
        <NewScenarioPage client:only="react" />
      </main>
    </div>
  </body>
</html>
